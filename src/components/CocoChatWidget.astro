---
// CocoChatWidget
---
<div id="coco-widget-container">
  <!-- Floating Action Button -->
  <button id="coco-fab" aria-label="Buka obrolan COCO" title="Ngobrol dengan COCO">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path>
      <path d="M9.5 9h5"></path>
      <path d="M9.5 13h2"></path>
    </svg>
  </button>

  <!-- Chat Modal -->
  <div id="coco-chat-modal" class="hidden">
    <div class="coco-header">
      <div class="coco-title-area">
        <h3 class="type-title-md">COCO</h3>
        <p class="type-label-md">Compendium Companion &amp; Bible AI</p>
      </div>
      <div style="display: flex; gap: 0.25rem; align-items: center;">
        <!-- Maximize button: hidden on mobile (already fullscreen) -->
        <button id="coco-max-btn" aria-label="Perbesar COCO" title="Perbesar tampilan" class="desktop-only-btn">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 3 21 3 21 9"></polyline><polyline points="9 21 3 21 3 15"></polyline><line x1="21" y1="3" x2="14" y2="10"></line><line x1="3" y1="21" x2="10" y2="14"></line></svg>
        </button>
        <button id="coco-close-btn" aria-label="Tutup COCO">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
        </button>
      </div>
    </div>
    
    <div id="coco-chat-history" class="coco-body">
      <!-- Chat messages will be injected here -->
      <div class="chat-message assistant">
        <div class="message-bubble assistant-bubble">
          <div class="type-body-md markdown-chat-content">Halo! Saya COCO. Anda bisa bertanya apa saja seputar Alkitab atau ajaran Katolik. Ada yang bisa saya bantu hari ini?</div>
        </div>
      </div>
    </div>
    
    <div id="coco-loading-state" style="display:none">
      <div class="coco-progress-wrap">
        <div class="coco-progress-header">
          <span class="type-label-md" id="coco-loading-text">Memuat Kompendium...</span>
          <span class="type-label-md" id="coco-progress-pct">0%</span>
        </div>
        <div class="coco-progress-bar-track">
          <div class="coco-progress-bar-fill" id="coco-progress-fill"></div>
        </div>
      </div>
    </div>

    <div class="coco-footer">
      <div class="coco-input-wrapper">
        <input type="text" id="coco-chat-input" placeholder="Ketik pertanyaan Anda di sini..." class="type-body-md" autocomplete="off" />
        <button id="coco-send-btn" aria-label="Kirim pesan">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
        </button>
      </div>
      <div class="coco-meta">
        <span class="type-label-md" style="opacity:0.6;">Sisa pesan hari ini: <span id="coco-chat-limit">20</span></span>
      </div>
    </div>
  </div>
</div>

<script is:inline src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
<script>
  // ----------------------------------------
  // COCO AI CHATBOT LOGIC (DUAL RAG)
  // ----------------------------------------
  const fab = document.getElementById('coco-fab');
  const modal = document.getElementById('coco-chat-modal');
  const closeBtn = document.getElementById('coco-close-btn');
  const maxBtn = document.getElementById('coco-max-btn');
  const chatInput = document.getElementById('coco-chat-input') as HTMLInputElement;
  const chatSendBtn = document.getElementById('coco-send-btn') as HTMLButtonElement;
  const chatHistory = document.getElementById('coco-chat-history');
  const chatTokenLimitEl = document.getElementById('coco-chat-limit');
  const loadingState = document.getElementById('coco-loading-state');
  const loadingText = document.getElementById('coco-loading-text');

  const MAX_DAILY_MESSAGES = 20;

  let compendiumData = null;
  let isDataLoaded = false;
  let isFetchingData = false;

  const checkDailyLimit = () => {
    const today = new Date().toDateString();
    const storedData = JSON.parse(localStorage.getItem('romo_ai_limit') || '{}');
    if (storedData.date !== today) {
      return MAX_DAILY_MESSAGES;
    }
    return storedData.remaining ?? MAX_DAILY_MESSAGES;
  };

  const updateDailyLimit = (remaining) => {
    const today = new Date().toDateString();
    localStorage.setItem('romo_ai_limit', JSON.stringify({ date: today, remaining }));
    if (chatTokenLimitEl) chatTokenLimitEl.textContent = remaining.toString();
    
    if (remaining <= 0) {
      chatInput.disabled = true;
      chatSendBtn.disabled = true;
      chatInput.placeholder = "Batas harian tercapai. Coba besok ya!";
      chatSendBtn.style.opacity = '0.5';
    }
  };

  let currentRemaining = checkDailyLimit();
  updateDailyLimit(currentRemaining);

  const openChat = () => {
    modal.classList.remove('hidden');
    fab.classList.add('hidden');
    // Lock background scroll
    document.body.style.overflow = 'hidden';
    if (!isDataLoaded) loadData();
    else chatInput.focus();
  };

  const closeChat = () => {
    modal.classList.remove('maximized');
    modal.classList.add('hidden');
    fab.classList.remove('hidden');
    // Restore background scroll
    document.body.style.overflow = '';
    isMaximized = false;
    if (maxBtn) {
      maxBtn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 3 21 3 21 9"></polyline><polyline points="9 21 3 21 3 15"></polyline><line x1="21" y1="3" x2="14" y2="10"></line><line x1="3" y1="21" x2="10" y2="14"></line></svg>';
    }
  };

  const appendMessage = (text, sender) => {
    const msgDiv = document.createElement('div');
    msgDiv.className = `chat-message ${sender}`;
    
    const bubble = document.createElement('div');
    bubble.className = `message-bubble ${sender === 'user' ? 'user-bubble' : 'assistant-bubble'}`;
    
    // @ts-ignore
    let formattedText = typeof marked !== 'undefined' ? marked.parse(text) : text.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>').replace(/\n/g, '<br/>');
    
    bubble.innerHTML = `<div class="type-body-md markdown-chat-content">${formattedText}</div>`;
    msgDiv.appendChild(bubble);
    chatHistory.appendChild(msgDiv);
    
    setTimeout(() => {
      chatHistory.scrollTop = chatHistory.scrollHeight;
    }, 50);
    
    return msgDiv;
  };

  let chatMemory = [];
  const MAX_MEMORY = 10;

  const getStopWords = () => ['apa', 'itu', 'dan', 'yang', 'di', 'ke', 'dari', 'bagaimana', 'mengapa', 'adalah', 'untuk', 'dengan', 'dalam', 'karena', 'maka', 'siapa', 'kapan', 'dimana'];

  const searchCatechismContext = (query) => {
    if (!compendiumData) return "";
    const keywords = query.toLowerCase().replace(/[^\w\s]/gi, '').split(' ').filter(w => w.length > 2 && !getStopWords().includes(w));
    if (keywords.length === 0) keywords.push(query.toLowerCase());

    let matches = [];
    compendiumData.forEach(pillar => {
      pillar.questions.forEach(qa => {
        let score = 0;
        const qText = qa.question.toLowerCase();
        const aText = qa.answer.toLowerCase();
        keywords.forEach(kw => {
          if (qText.includes(kw)) score += 2;
          if (aText.includes(kw)) score += 1;
        });
        if (score > 0) matches.push({ score, text: `Tanya: ${qa.question}\nJawab: ${qa.answer}\nRef: ${qa.reference}` });
      });
    });
    matches.sort((a, b) => b.score - a.score);
    return matches.slice(0, 3).map(m => m.text).join("\n\n");
  };


  const GROQ_MODELS = [
    "llama-3.3-70b-versatile",
    "llama-3.1-8b-instant",
    "mixtral-8x7b-32768",
    "gemma2-9b-it"
  ];

  const fetchGroqChat = async (messages) => {
    let lastError = null;
    for (const model of GROQ_MODELS) {
      try {
        const res = await fetch("/api/chat", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ model: model, messages: messages })
        });
        const data = await res.json();
        if (res.ok && data.choices && data.choices[0]) return data;
        lastError = data.error?.message || JSON.stringify(data);
        if (res.status === 401) break; 
        console.warn(`[COCO] Model ${model} gagal: ${lastError}`);
        continue;
      } catch (err) {
        lastError = err.message;
        continue; 
      }
    }
    throw new Error(lastError || "Seluruh model AI gagal merespons.");
  };

  const setProgress = (pct) => {
    const fill = document.getElementById('coco-progress-fill');
    const label = document.getElementById('coco-progress-pct');
    if (fill) fill.style.width = `${pct}%`;
    if (label) label.textContent = `${Math.round(pct)}%`;
  };

  const loadData = async () => {
    if (isDataLoaded || isFetchingData) return;
    isFetchingData = true;
    loadingState.style.display = 'flex';
    loadingText.textContent = "Memuat Kompendium...";
    setProgress(0);
    
    try {
      const resComp = await fetch('/data/catechism-compendium.json');
      if (!resComp.ok) throw new Error('Gagal mengunduh kompendium');

      // Track download progress via ReadableStream
      const contentLength = resComp.headers.get('Content-Length');
      const total = contentLength ? parseInt(contentLength) : 520367; // fallback to known size
      let received = 0;
      const reader = resComp.body.getReader();
      const chunks = [];

      while (true) {
        const { done, value } = await reader.read();
        if (done) break;
        chunks.push(value);
        received += value.length;
        const pct = Math.min(98, (received / total) * 100);
        setProgress(pct);
      }

      // Combine chunks and parse JSON
      setProgress(99);
      const allBytes = new Uint8Array(received);
      let pos = 0;
      for (const chunk of chunks) {
        allBytes.set(chunk, pos);
        pos += chunk.length;
      }
      const text = new TextDecoder().decode(allBytes);
      compendiumData = JSON.parse(text);
      setProgress(100);
      isDataLoaded = true;
    } catch (e) {
      console.error("Gagal memuat kompendium:", e);
      isDataLoaded = true;
    } finally {
      isFetchingData = false;
      // Short delay so user sees 100%
      setTimeout(() => {
        loadingState.style.display = 'none';
        chatInput.focus();
      }, 400);
    }
  };

  const handleSendMessage = async () => {
    const text = chatInput.value.trim();
    if (!text || currentRemaining <= 0) return;
    
    appendMessage(text, 'user');
    chatInput.value = '';
    currentRemaining--;
    updateDailyLimit(currentRemaining);
    
    const loadingBubble = appendMessage("Berpikir...", 'assistant');

    try {
      await new Promise(r => setTimeout(r, 10));
      
      const compContext = searchCatechismContext(text);
      
      const systemPrompt = `Anda adalah COCO (Compendium Companion), asisten Katolik virtual di aplikasi "Pelita". 
Jawablah dengan penuh kasih, ringkas, dan berwibawa dalam Bahasa Indonesia.

ANDA BERBASIS PADA:
- Kompendium Katekismus Gereja Katolik (KGK)
- Pengetahuan teologi Katolik yang benar

ATURAN WAJIB:
- Jika Anda mengutip dari Kompendium dalam konteks di bawah, WAJIB cantumkan referensinya (misal: "Bdk. KGK 123" atau "Kompendium no. 45").
- Jika menyebut ayat Alkitab, tulis referensinya dengan benar (misal: "Yoh 3:16", "Kej 1:1").
- Jangan berhalusinasi. Jika pertanyaan di luar ajaran Katolik, tolak dengan sopan.
- Jawaban RINGKAS dan JELAS. Hindari bullet point berlebihan.

KONTEKS KOMPENDIUM:
---
${compContext}
---`;

      let apiMessages = [{ role: "system", content: systemPrompt }];
      apiMessages.push(...chatMemory);
      apiMessages.push({ role: "user", content: text });

      const data = await fetchGroqChat(apiMessages);
      loadingBubble.remove();
      
      const answerText = data.choices[0].message.content;
      appendMessage(answerText, 'assistant');
      
      chatMemory.push({ role: "user", content: text });
      chatMemory.push({ role: "assistant", content: answerText });
      
      if (chatMemory.length > MAX_MEMORY) chatMemory = chatMemory.slice(chatMemory.length - MAX_MEMORY);
    } catch (err) {
      loadingBubble.remove();
      appendMessage(`Maaf, terjadi kesalahan: ${err.message}`, 'assistant');
      currentRemaining++;
      updateDailyLimit(currentRemaining);
    }
  };

  // Event Listeners
  fab.addEventListener('click', openChat);
  closeBtn.addEventListener('click', closeChat);

  // Maximize (desktop only)
  let isMaximized = false;
  if (maxBtn) {
    maxBtn.addEventListener('click', () => {
      isMaximized = !isMaximized;
      if (isMaximized) {
        modal.classList.add('maximized');
        maxBtn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 14 10 14 10 20"></polyline><polyline points="20 10 14 10 14 4"></polyline><line x1="14" y1="10" x2="21" y2="3"></line><line x1="3" y1="21" x2="10" y2="14"></line></svg>';
      } else {
        modal.classList.remove('maximized');
        maxBtn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 3 21 3 21 9"></polyline><polyline points="9 21 3 21 3 15"></polyline><line x1="21" y1="3" x2="14" y2="10"></line><line x1="3" y1="21" x2="10" y2="14"></line></svg>';
      }
      chatInput.focus();
    });
  }

  chatSendBtn.addEventListener('click', handleSendMessage);
  chatInput.addEventListener('keypress', (e) => {
    if (e.key === 'Enter') handleSendMessage();
  });
</script>

<style>
  /* FAB Styles */
  #coco-fab {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    width: 60px;
    height: 60px;
    border-radius: 50%;
    background: var(--color-primary);
    color: white;
    border: none;
    box-shadow: var(--shadow-ambient);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 9999;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  #coco-fab:hover {
    transform: scale(1.05) translateY(-2px);
    box-shadow: 0 10px 25px rgba(68, 42, 34, 0.3);
  }
  #coco-fab svg {
    width: 28px;
    height: 28px;
  }
  #coco-fab.hidden {
    display: none;
  }

  /* Modal Styles */
  #coco-chat-modal {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    width: 380px;
    max-width: calc(100vw - 2rem);
    height: 600px;
    max-height: calc(100vh - 4rem);
    background: var(--surface);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-ambient);
    display: flex;
    flex-direction: column;
    z-index: 10000;
    overflow: hidden;
    border: 1px solid var(--outline-variant);
    transition: all 0.3s cubic-bezier(0.2, 0, 0, 1);
  }
  #coco-chat-modal.maximized {
    width: 100vw;
    height: 100vh;
    max-width: 100vw;
    max-height: 100vh;
    bottom: 0;
    right: 0;
    border-radius: 0;
    border: none;
  }
  #coco-chat-modal.hidden {
    display: none;
  }

  .coco-header {
    background: var(--color-primary);
    color: white;
    padding: 1.25rem 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    /* Ensure header is above safe-area on iOS */
    padding-top: max(1.25rem, env(safe-area-inset-top));
    flex-shrink: 0;
  }
  .coco-title-area h3 {
    margin: 0;
    font-size: 1.25rem;
  }
  .coco-title-area p {
    margin: 0;
    opacity: 0.8;
  }
  #coco-close-btn, #coco-max-btn {
    background: none;
    border: none;
    color: white;
    cursor: pointer;
    opacity: 0.8;
    padding: 0.5rem;
    border-radius: 50%;
    transition: background 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 40px;
    min-height: 40px;
  }
  #coco-close-btn:hover, #coco-max-btn:hover {
    opacity: 1;
    background: rgba(255,255,255,0.1);
  }

  .coco-body {
    flex: 1;
    overflow-y: auto;
    overflow-x: hidden;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    background: var(--surface-container-lowest);
    /* Ensure it doesn't overflow the modal width */
    min-width: 0;
  }

  /* Chat messages — must use :global() because elements are created dynamically via JS */
  :global(.chat-message) {
    display: flex;
    flex-direction: column;
    max-width: 100%;
  }
  :global(.chat-message.user) {
    align-items: flex-end;
    align-self: flex-end;
  }
  :global(.chat-message.assistant) {
    align-items: flex-start;
    align-self: flex-start;
  }

  :global(.message-bubble) {
    padding: 0.875rem 1.25rem;
    max-width: 85%;
    word-wrap: break-word;
    overflow-wrap: break-word;
    min-width: 0;
  }
  :global(.user-bubble) {
    border-radius: var(--radius-md) var(--radius-md) 0 var(--radius-md);
    background: var(--color-primary);
    color: white;
  }
  :global(.assistant-bubble) {
    border-radius: 0 var(--radius-md) var(--radius-md) var(--radius-md);
    background: var(--surface-container-high);
    color: var(--on-surface);
  }

  /* Markdown content fix: prevent numbered lists from overflowing */
  :global(.markdown-chat-content) {
    line-height: 1.6;
    margin: 0;
    overflow-wrap: break-word;
    word-wrap: break-word;
    min-width: 0;
  }
  :global(.markdown-chat-content ol),
  :global(.markdown-chat-content ul) {
    padding-left: 1.5rem;
    margin: 0.5rem 0;
  }
  :global(.markdown-chat-content li) {
    margin-bottom: 0.25rem;
  }
  :global(.markdown-chat-content p) {
    margin: 0 0 0.5rem 0;
  }
  :global(.markdown-chat-content p:last-child) {
    margin-bottom: 0;
  }
  :global(.markdown-chat-content strong) {
    font-weight: 700;
  }

  #coco-loading-state {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    padding: 1rem;
    background: var(--surface-container-low);
    color: var(--on-surface-variant);
    font-size: 0.875rem;
    flex-shrink: 0;
  }

  /* Progress bar */
  .coco-progress-wrap {
    width: 100%;
    padding: 0 0.5rem;
  }
  .coco-progress-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.5rem;
    color: var(--on-surface-variant);
  }
  .coco-progress-bar-track {
    width: 100%;
    height: 6px;
    background: var(--outline-variant);
    border-radius: 999px;
    overflow: hidden;
  }
  .coco-progress-bar-fill {
    height: 100%;
    width: 0%;
    background: var(--color-primary);
    border-radius: 999px;
    transition: width 0.25s ease-out;
  }

  .coco-footer {
    padding: 1rem;
    background: var(--surface);
    border-top: 1px solid var(--outline-variant);
    flex-shrink: 0;
    /* Reserve space for browser nav bar on mobile */
    padding-bottom: max(1rem, env(safe-area-inset-bottom));
  }
  .coco-input-wrapper {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
  }
  #coco-chat-input {
    flex: 1;
    padding: 0.75rem 1rem;
    border-radius: var(--radius-full);
    border: 1px solid var(--outline-variant);
    background: var(--surface-container-lowest);
    color: var(--on-surface);
    outline: none;
    transition: border-color 0.2s;
    min-width: 0;
    font-size: 1rem; /* Prevent iOS auto-zoom on focus */
  }
  #coco-chat-input:focus {
    border-color: var(--color-primary);
  }
  #coco-send-btn {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--color-primary);
    color: white;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
    flex-shrink: 0;
  }
  #coco-send-btn:hover {
    background: var(--color-secondary);
  }
  #coco-send-btn:disabled {
    background: var(--surface-container-highest);
    cursor: not-allowed;
  }

  .coco-meta {
    text-align: center;
  }

  /* On mobile: fullscreen by default, hide maximize button */
  @media (max-width: 640px) {
    #coco-chat-modal {
      bottom: 0;
      right: 0;
      left: 0;
      width: 100%;
      max-width: 100%;
      height: 100%;
      max-height: 100%;
      border-radius: 0;
      border: none;
    }
    .desktop-only-btn {
      display: none;
    }
  }
</style>
