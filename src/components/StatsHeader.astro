---
import booksConfig from '../data/bible-metadata.json';
// StatsHeader.astro Rebuilt
---

<header class="sacred-topbar">
  <div class="topbar-content container">
    <div class="brand">
      <a href="/" class="brand-link">
        <div class="brand-title type-title-lg">Pelita</div>
        <div class="brand-subtitle type-label-md">Lentera Iman Katolik</div>
      </a>
    </div>
    <nav class="sacred-nav">
      <a href="/" id="navBookshelf" class="nav-link type-label-md">Rak Buku</a>
      <a href="/read/kej" id="navReadings" class="nav-link type-label-md">Bacaan</a>
      <a href="/sanctuary" id="navSanctuary" class="nav-link type-label-md">Sanctuari</a>
      <a href="/kompendium" id="navCatechism" class="nav-link type-label-md">Kompendium</a>
    </nav>
    <div class="actions">
      <button aria-label="Search" class="icon-btn" id="headerSearchBtn">
        <svg fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="20" height="20">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z"></path>
        </svg>
      </button>
      <button aria-label="Settings" class="icon-btn" id="headerSettingsBtn">
        <svg fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="20" height="20">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.324.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 011.37.49l1.296 2.247a1.125 1.125 0 01-.26 1.431l-1.003.827c-.293.24-.438.613-.431.992a6.759 6.759 0 010 .255c-.007.378.138.75.43.99l1.005.828c.424.35.534.954.26 1.43l-1.298 2.247a1.125 1.125 0 01-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.57 6.57 0 01-.22.128c-.331.183-.581.495-.644.869l-.213 1.28c-.09.543-.56.941-1.11.941h-2.594c-.55 0-1.02-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 01-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 01-1.369-.49l-1.297-2.247a1.125 1.125 0 01.26-1.431l1.004-.827c.292-.24.437-.613.43-.992a6.932 6.932 0 010-.255c.007-.378-.138-.75-.43-.99l-1.004-.828a1.125 1.125 0 01-.26-1.43l1.297-2.247a1.125 1.125 0 011.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.087.22-.128.332-.183.582-.495.644-.869l.214-1.281z"></path>
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
        </svg>
      </button>
    </div>
  </div>
  
  <!-- A. SLEEK SEARCH OVERLAY -->
  <div class="search-overlay" id="searchOverlay">
    <div class="search-overlay-content container">
      <svg fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="20" height="20" class="search-bar-icon">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z"></path>
      </svg>
      <input type="text" id="globalSearchInput" placeholder="Cari ayat, kitab, atau kompendium KGK..." aria-label="Cari secara global" autocomplete="off">
      <button class="close-search-btn" id="closeSearchBtn" aria-label="Tutup Pencarian">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" width="20" height="20"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
      </button>
    </div>
    <!-- Autocomplete Dropdown List -->
    <div class="search-results-dropdown" id="searchResultsDropdown" style="display: none;">
      <div class="results-container container">
        <!-- Two column panels: Bible | KGK -->
        <div class="search-panels">
          <div class="search-panel" id="panelBible">
            <div class="panel-label type-label-md">ALKITAB</div>
            <div class="panel-results" id="bibleResults"></div>
          </div>
          <div class="search-panel" id="panelKGK">
            <div class="panel-label type-label-md">KOMPENDIUM KGK</div>
            <div class="panel-results" id="kgkResults"></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</header>

<!-- B. UNIFIED SETTINGS DRAWER -->
<div class="settings-drawer-backdrop" id="settingsDrawerBackdrop"></div>
<div class="settings-drawer" id="globalSettingsDrawer">
  <div class="drawer-header">
    <span class="type-label-md header-title">KONSTURISASI TAMPILAN</span>
    <button class="close-drawer-btn" id="closeGlobalSettings" aria-label="Tutup Pengaturan">
      <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" width="20" height="20"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
    </button>
  </div>
  <div class="drawer-body">
    <!-- 1. Theme Selection -->
    <div class="setting-section">
      <label class="type-label-md setting-label">TEMA TAMPILAN</label>
      <div class="theme-grid">
        <button class="theme-option" data-theme="light">
          <div class="theme-preview" style="background: #faf9f8; border: 1px solid rgba(44,26,22,0.15)"></div>
          <span class="type-label-md preview-name">TERANG</span>
        </button>
        <button class="theme-option" data-theme="dark">
          <div class="theme-preview" style="background: #1e1a17; border: 1px solid rgba(240,236,230,0.15)"></div>
          <span class="type-label-md preview-name">GELAP</span>
        </button>
        <button class="theme-option" data-theme="soft">
          <div class="theme-preview" style="background: #f5ede8;"></div>
          <span class="type-label-md preview-name">LEMBUT</span>
        </button>
        <button class="theme-option" data-theme="zen">
          <div class="theme-preview" style="background: #fce8e8;"></div>
          <span class="type-label-md preview-name">ZEN</span>
        </button>
      </div>
    </div>
    <!-- 2. Text Size Selection -->
    <div class="setting-section">
      <div class="range-header">
        <label class="type-label-md setting-label">UKURAN TEKS</label>
        <span class="type-label-md value-display" id="globalTextSizeVal">Sedang</span>
      </div>
      <div class="range-slider">
        <input type="range" id="globalTextSizeSlider" min="12" max="24" value="16">
      </div>
    </div>
    <!-- 3. Verses Per Card Selection (for StoryReader pages) -->
    <div class="setting-section" id="globalVpcSection" style="display: none;">
      <div class="range-header">
        <label class="type-label-md setting-label">KERAPATAN TEKS</label>
        <span class="type-label-md value-display" id="globalVpcVal">3 Ayat</span>
      </div>
      <div class="range-slider">
        <input type="range" id="globalVpcSlider" min="1" max="10" value="3">
      </div>
    </div>
  </div>
</div>

<style>
.sacred-topbar{position:sticky;top:0;z-index:50;background:var(--surface-variant);backdrop-filter:blur(24px);-webkit-backdrop-filter:blur(24px);border-bottom:1px solid var(--outline-variant);padding:1.5rem 0;transition:background-color var(--duration-normal),border-color var(--duration-normal)}
.topbar-content{display:flex;justify-content:space-between;align-items:center}
.brand-link{display:flex;flex-direction:column;gap:.25rem}
.brand-title{color:var(--on-surface);font-style:italic;transition:color var(--duration-normal)}
.brand-subtitle{color:var(--on-surface-variant);opacity:.85;transition:color var(--duration-normal)}
.sacred-nav{display:none;gap:2.5rem}
@media(min-width:768px){.sacred-nav{display:flex}
}
.nav-link{color:var(--on-surface-variant);font-weight:600;position:relative;padding-bottom:.25rem;cursor:pointer;transition:color var(--duration-fast) var(--ease-out-expo)}
.nav-link:hover,.nav-link.active{color:var(--on-surface)}
.nav-link.active:after{content:"";position:absolute;bottom:-8px;left:0;width:100%;height:1px;background-color:var(--color-primary)}
.actions{display:flex;gap:1.25rem}
.icon-btn{background:transparent;border:none;color:var(--on-surface);opacity:.7;transition:opacity var(--duration-fast) var(--ease-out-expo),color var(--duration-normal);display:grid;place-items:center;cursor:pointer}
.icon-btn:hover{opacity:1;color:var(--color-primary)}
.search-overlay{position:fixed;top:0;left:0;right:0;bottom:0;height:100vh;background:var(--surface);z-index:9999;padding:1.5rem 0;transform:translateY(-100%);opacity:0;pointer-events:none;transition:transform var(--duration-normal) var(--ease-out-expo),opacity var(--duration-normal) var(--ease-out-expo);display:flex;flex-direction:column}
.search-overlay.active{transform:translateY(0);opacity:1;pointer-events:auto}
.search-overlay-content{display:flex;align-items:center;gap:1rem;position:relative}
.search-bar-icon{color:var(--color-secondary)}
#globalSearchInput{flex-grow:1;background:transparent;border:none;font-family:var(--font-serif);font-size:1.25rem;color:var(--on-surface);outline:none}
#globalSearchInput::placeholder{color:var(--on-surface-variant);opacity:.6;font-style:italic}
.close-search-btn{background:transparent;border:none;color:var(--on-surface-variant);cursor:pointer;display:grid;place-items:center;opacity:.7;transition:opacity var(--duration-fast)}
.close-search-btn:hover{opacity:1;color:var(--color-primary)}
.search-results-dropdown{flex:1;overflow-y:auto;width:100%;margin-top:1.25rem;padding-bottom:3rem;background:transparent}
.search-panels{display:grid;grid-template-columns:1fr;gap:0;padding:0}
@media(min-width:720px){.search-panels{grid-template-columns:1fr 1fr}}
.search-panel{padding:1rem 0 1.25rem}
.search-panel+.search-panel{border-top:1px solid var(--outline-variant)}
@media(min-width:720px){.search-panel+.search-panel{border-top:none;border-left:1px solid var(--outline-variant);padding-left:1.5rem}}
.panel-label{color:var(--color-secondary);font-weight:700;letter-spacing:.08em;font-size:.65rem;padding:0.5rem 0 0.75rem;margin-bottom:0}
.panel-results{display:flex;flex-direction:column;gap:.5rem}

.settings-drawer-backdrop{position:fixed;inset:0;background:#1e1a1766;backdrop-filter:blur(4px);-webkit-backdrop-filter:blur(4px);z-index:999;opacity:0;pointer-events:none;transition:opacity var(--duration-normal) var(--ease-out-expo)}
.settings-drawer-backdrop.active{opacity:1;pointer-events:auto}
.settings-drawer{position:fixed;top:0;right:0;bottom:0;width:100%;max-width:320px;background:var(--surface);border-left:1px solid var(--outline-variant);padding:2.5rem 2rem;z-index:1000;box-shadow:var(--shadow-ambient);transform:translate(105%);transition:transform var(--duration-normal) var(--ease-out-expo);display:flex;flex-direction:column;gap:2rem}
.settings-drawer.active{transform:translate(0)}
.drawer-header{display:flex;justify-content:space-between;align-items:center}
.drawer-header .header-title{color:var(--color-primary);font-weight:700;letter-spacing:.1em}
.close-drawer-btn{background:transparent;border:none;color:var(--on-surface-variant);cursor:pointer;display:grid;place-items:center;opacity:.7;transition:opacity var(--duration-fast)}
.close-drawer-btn:hover{opacity:1;color:var(--color-primary)}
.drawer-body{display:flex;flex-direction:column;gap:2.25rem;flex:1}
.setting-section{display:flex;flex-direction:column;gap:.75rem}
.setting-label{color:var(--color-secondary);font-weight:700;letter-spacing:.08em}
.theme-grid{display:grid;grid-template-columns:1fr 1fr;gap:.75rem}
.theme-option{background:transparent;border:none;display:flex;flex-direction:column;gap:.35rem;align-items:center;cursor:pointer}
.theme-preview{width:100%;height:52px;border-radius:var(--radius-md);box-shadow:var(--shadow-subtle);transition:transform var(--duration-fast)}
.theme-option:hover .theme-preview{transform:scale(1.02)}
.theme-option.active .theme-preview{border:2px solid var(--color-primary)!important}
.preview-name{font-size:.65rem;letter-spacing:.05em;color:var(--on-surface-variant)}
.theme-option.active .preview-name{color:var(--color-primary);font-weight:700}
.range-header{display:flex;justify-content:space-between;align-items:center}
.value-display{color:var(--color-primary);font-weight:700}
.range-slider input{width:100%;accent-color:var(--color-primary);cursor:pointer;background:var(--outline-variant);height:4px;border-radius:var(--radius-full);outline:none}

</style>

<style is:global>
.search-result-item{background:var(--surface-container);padding:.875rem 1rem;border-radius:var(--radius-md);display:flex;justify-content:space-between;align-items:center;border:1px solid var(--outline-variant);transition:all var(--duration-fast) var(--ease-out-expo);text-decoration:none;color:inherit}
.search-result-item:hover{border-color:var(--color-primary);background:var(--surface-container-high);transform:translateX(2px)}
.result-details{display:flex;flex-direction:column;gap:.2rem;flex:1;min-width:0}
.result-name{font-family:var(--font-serif);font-weight:700;font-size:1rem;color:var(--color-primary);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.result-snippet{font-size:.78rem;color:var(--on-surface-variant);line-height:1.4;overflow:hidden;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical}
.result-meta{font-size:.62rem;color:var(--on-surface-variant);letter-spacing:.05em;margin-top:.1rem}
.result-arrow{color:var(--color-secondary);opacity:.5;transition:transform var(--duration-fast);flex-shrink:0;margin-left:.5rem}
.search-result-item:hover .result-arrow{opacity:1;transform:translateX(3px)}
.no-results-msg{text-align:center;padding:1.5rem 0;color:var(--on-surface-variant);font-style:italic;font-size:.9rem}
.search-loading{text-align:center;padding:1rem 0;color:var(--on-surface-variant);font-size:.85rem;opacity:.7}
</style>

<script define:vars={{ booksConfig }}>
try {
    // Search Overlay Logic
    const searchBtn = document.getElementById('headerSearchBtn');
    const closeSearchBtn = document.getElementById('closeSearchBtn');
    const searchOverlay = document.getElementById('searchOverlay');
    const searchInput = document.getElementById('globalSearchInput');
    const searchResultsDropdown = document.getElementById('searchResultsDropdown');
    const searchResultsGrid = document.getElementById('searchResultsGrid');
    
    // Settings Drawer Logic
    const settingsBtn = document.getElementById('headerSettingsBtn');
    const closeSettingsBtn = document.getElementById('closeGlobalSettings');
    const settingsDrawer = document.getElementById('globalSettingsDrawer');
    const settingsBackdrop = document.getElementById('settingsDrawerBackdrop');
    
    const themeOptions = document.querySelectorAll('.theme-option');
    const textSizeSlider = document.getElementById('globalTextSizeSlider');
    const textSizeVal = document.getElementById('globalTextSizeVal');

    // Open/Close functions
    function openSearch() {
        if(searchOverlay) {
            searchOverlay.classList.add('active');
            setTimeout(() => { if(searchInput) searchInput.focus(); }, 100);
        }
    }
    function closeSearch() {
        if(searchOverlay) {
            searchOverlay.classList.remove('active');
            if (searchInput) searchInput.value = '';
            if (searchResultsDropdown) searchResultsDropdown.style.display = 'none';
        }
    }
    function openSettings() {
        if(settingsDrawer) settingsDrawer.classList.add('active');
        if(settingsBackdrop) settingsBackdrop.classList.add('active');
        document.body.classList.add('no-scroll');
    }
    function closeSettings() {
        if(settingsDrawer) settingsDrawer.classList.remove('active');
        if(settingsBackdrop) settingsBackdrop.classList.remove('active');
        document.body.classList.remove('no-scroll');
    }

    if(searchBtn) searchBtn.addEventListener('click', openSearch);
    if(closeSearchBtn) closeSearchBtn.addEventListener('click', closeSearch);
    if(settingsBtn) settingsBtn.addEventListener('click', openSettings);
    if(closeSettingsBtn) closeSettingsBtn.addEventListener('click', closeSettings);
    if(settingsBackdrop) settingsBackdrop.addEventListener('click', closeSettings);

    // --- Smart Lazy-Load Search Logic ---
    const bibleResultsEl = document.getElementById('bibleResults');
    const kgkResultsEl = document.getElementById('kgkResults');
    
    // KGK compendium data - loaded once on first search
    let kgkData = null;
    // Per-book Bible verse cache: {bookId: [[chapter, verse, snippet], ...]}
    const bookCache = {};
    let searchDebounce = null;
    let firstResultUrl = '';

    const arrowSvg = `<svg class="result-arrow" fill="none" viewBox="0 0 24 24" stroke="currentColor" width="16" height="16"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>`;

    /** Render bible book-level hits (no verse loading needed) */
    function renderBibleBookHits(query) {
        if (!booksConfig || !bibleResultsEl) return;
        const hits = booksConfig.filter(b =>
            b.name.toLowerCase().includes(query) ||
            b.category.toLowerCase().includes(query) ||
            b.subCategory.toLowerCase().includes(query)
        ).slice(0, 5);

        if (hits.length === 0) {
            bibleResultsEl.innerHTML = `<div class="no-results-msg">Tidak ditemukan.</div>`;
            return;
        }
        firstResultUrl = `/read/${hits[0].id}`;
        bibleResultsEl.innerHTML = hits.map(b => `
            <a href="/read/${b.id}" class="search-result-item">
                <div class="result-details">
                    <span class="result-name">${b.name}</span>
                    <span class="result-meta">${b.category} · ${b.chapters} Bab</span>
                </div>
                ${arrowSvg}
            </a>
        `).join('');
    }

    /** Lazy-load a book's verse index on demand */
    async function loadBookIndex(bookId) {
        if (bookCache[bookId]) return bookCache[bookId];
        try {
            const res = await fetch(`/search/${bookId}.json`);
            if (!res.ok) return [];
            const data = await res.json();
            bookCache[bookId] = data;
            return data;
        } catch { return []; }
    }

    /** Search verses across matching books (lazy per-book loading) */
    async function searchVerses(query) {
        if (!booksConfig || !bibleResultsEl) return;
        // Show loading state
        bibleResultsEl.innerHTML = `<div class="search-loading">Mencari ayat...</div>`;

        // Find books matching the query by name first
        const matchingBooks = booksConfig.filter(b =>
            b.name.toLowerCase().includes(query) ||
            b.category.toLowerCase().includes(query) ||
            b.subCategory.toLowerCase().includes(query)
        );

        // Also search for verse text in matching books (load at most 3 books to stay fast)
        const booksToSearch = matchingBooks.slice(0, 3);
        
        // If it's a short query that might be a word in a verse, search more broadly
        const isVerseSearch = query.length >= 4 && matchingBooks.length === 0;
        if (isVerseSearch) {
            // Sample a few common books for verse text search
            const sampleIds = ['mat', 'yoh', 'maz', 'rm', 'kej'];
            sampleIds.forEach(id => {
                const b = booksConfig.find(x => x.id === id);
                if (b && !booksToSearch.includes(b)) booksToSearch.push(b);
            });
        }

        const verseHits = [];
        for (const book of booksToSearch.slice(0, 4)) {
            const verses = await loadBookIndex(book.id);
            for (const [ch, v, snippet] of verses) {
                if (snippet.toLowerCase().includes(query)) {
                    verseHits.push({ book, ch, v, snippet });
                    if (verseHits.length >= 6) break;
                }
            }
            if (verseHits.length >= 6) break;
        }

        let html = '';
        // Book-level hits first
        matchingBooks.slice(0, 3).forEach(b => {
            html += `<a href="/read/${b.id}" class="search-result-item">
                <div class="result-details">
                    <span class="result-name">${b.name}</span>
                    <span class="result-meta">${b.category} · ${b.chapters} Bab</span>
                </div>${arrowSvg}</a>`;
            if (!firstResultUrl) firstResultUrl = `/read/${b.id}`;
        });
        // Verse hits
        verseHits.slice(0, 5).forEach(({ book, ch, v, snippet }) => {
            const highlighted = snippet.replace(new RegExp(`(${query})`, 'gi'), '<mark style="background:var(--color-secondary);color:var(--on-surface);border-radius:2px;padding:0 2px">$1</mark>');
            html += `<a href="/read/${book.id}/${ch}" class="search-result-item">
                <div class="result-details">
                    <span class="result-name">${book.name} ${ch}:${v}</span>
                    <span class="result-snippet">${highlighted}</span>
                </div>${arrowSvg}</a>`;
            if (!firstResultUrl) firstResultUrl = `/read/${book.id}/${ch}`;
        });

        bibleResultsEl.innerHTML = html || `<div class="no-results-msg">Tidak ditemukan ayat terkait.</div>`;
    }

    /** Search KGK compendium (load once, then filter in-memory) */
    async function searchKGK(query) {
        if (!kgkResultsEl) return;
        if (!kgkData) {
            kgkResultsEl.innerHTML = `<div class="search-loading">Memuat kompendium...</div>`;
            try {
                const res = await fetch('/catechism-compendium.json');
                if (!res.ok) { kgkResultsEl.innerHTML = ''; return; }
                const raw = await res.json();
                kgkData = [];
                raw.forEach(pillar => {
                    (pillar.questions || []).forEach(q => {
                        kgkData.push({ id: q.id, q: q.question, a: q.answer, ref: q.reference });
                    });
                });
            } catch { kgkResultsEl.innerHTML = ''; return; }
        }

        const hits = kgkData.filter(q =>
            q.q.toLowerCase().includes(query) ||
            q.a.toLowerCase().includes(query)
        ).slice(0, 5);

        if (!hits.length) {
            kgkResultsEl.innerHTML = `<div class="no-results-msg">Tidak ditemukan di KGK.</div>`;
            return;
        }
        kgkResultsEl.innerHTML = hits.map(q => {
            const snippet = q.a.substring(0, 90) + (q.a.length > 90 ? '…' : '');
            return `<a href="/katekismus#q${q.id}" class="search-result-item">
                <div class="result-details">
                    <span class="result-name" style="white-space:normal;-webkit-line-clamp:2;display:-webkit-box;-webkit-box-orient:vertical;overflow:hidden">${q.q}</span>
                    <span class="result-snippet">${snippet}</span>
                    <span class="result-meta">${q.ref || ''}</span>
                </div>${arrowSvg}</a>`;
        }).join('');
    }

    if (searchInput && searchResultsDropdown) {
        searchInput.addEventListener('input', (e) => {
            const query = e.target.value.trim().toLowerCase();
            if (query.length < 2) {
                searchResultsDropdown.style.display = 'none';
                return;
            }
            searchResultsDropdown.style.display = 'block';
            firstResultUrl = '';

            clearTimeout(searchDebounce);
            // Immediate book-level results (from booksConfig already in memory)
            renderBibleBookHits(query);
            if (kgkResultsEl) kgkResultsEl.innerHTML = `<div class="search-loading">Mencari...</div>`;

            // Debounce heavier async searches
            searchDebounce = setTimeout(async () => {
                await Promise.all([searchVerses(query), searchKGK(query)]);
            }, 280);
        });

        searchInput.addEventListener('keydown', (e) => {
            if (e.key === 'Enter' && firstResultUrl) {
                window.location.href = firstResultUrl;
            }
            if (e.key === 'Escape') closeSearch();
        });
    }

    // Theme Switcher
    const savedTheme = localStorage.getItem('alkitab_theme') || 'light';
    document.documentElement.setAttribute('data-theme', savedTheme);
    themeOptions.forEach(opt => {
        if(opt.getAttribute('data-theme') === savedTheme) opt.classList.add('active');
        opt.addEventListener('click', () => {
            themeOptions.forEach(o => o.classList.remove('active'));
            opt.classList.add('active');
            const theme = opt.getAttribute('data-theme');
            document.documentElement.setAttribute('data-theme', theme);
            localStorage.setItem('alkitab_theme', theme);
        });
    });

    // Text Size
    const sizeMap = {
        12: 'Sangat Kecil', 14: 'Kecil', 16: 'Sedang',
        18: 'Besar', 20: 'Sangat Besar', 22: 'Ekstra Besar', 24: 'Maksimal'
    };
    const savedSize = localStorage.getItem('alkitab_textSize') || '16';
    if(textSizeSlider) {
        textSizeSlider.value = savedSize;
        if(textSizeVal) textSizeVal.textContent = sizeMap[savedSize] || savedSize + 'px';
        
        textSizeSlider.addEventListener('input', (e) => {
            const val = e.target.value;
            if(textSizeVal) textSizeVal.textContent = sizeMap[val] || val + 'px';
            document.documentElement.style.setProperty('--type-body-lg', (val / 16) + 'rem');
            localStorage.setItem('alkitab_textSize', val);
        });
        document.documentElement.style.setProperty('--type-body-lg', (savedSize / 16) + 'rem');
    }

} catch (err) {
  console.error("StatsHeader logic error:", err);
}
</script>
