<script>
  class BookGuide extends HTMLElement {
    constructor() {
      super();
    }
    
    connectedCallback() {
      this.bookId = this.dataset.bookId;
      this.bookName = this.dataset.bookName;
      
      this.state = {
        theme: localStorage.getItem('alkitab_theme') || 'light',
        textSize: parseInt(localStorage.getItem('alkitab_textSize') || '16'),
      };
      
      this.applyTheme();
      this.setupTabs();
      this.setupControls();
      this.setupBookmark();
      this.setupShareModal();
    }
    
    applyTheme() {
      document.documentElement.setAttribute('data-theme', this.state.theme);
    }
    
    setupTabs() {
      const tabButtons = this.querySelectorAll('.tab-btn');
      const tabContents = this.querySelectorAll('.tab-content');
      
      tabButtons.forEach(btn => {
        btn.addEventListener('click', (e) => {
          const target = (e.currentTarget as HTMLElement).dataset.tab;
          
          tabButtons.forEach(b => b.classList.remove('active'));
          tabContents.forEach(c => c.classList.remove('active'));
          
          (e.currentTarget as HTMLElement).classList.add('active');
          const targetContent = this.querySelector(`#content-${target}`);
          if (targetContent) targetContent.classList.add('active');
          
          // Smooth scroll to top of tab view if needed
          const tabsBar = this.querySelector('#stickyTabs');
          if (tabsBar) {
            tabsBar.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }
        });
      });
    }
    
    setupControls() {
      // Listen to unified settings events from StatsHeader
      window.addEventListener('global-theme-changed', (e: any) => {
        this.state.theme = e.detail.theme;
        this.applyTheme();
      });
    }

    setupShareModal() {
      const cards = this.querySelectorAll('.verse-vellum-card');
      const modal = this.querySelector('#shareModal');
      const closeBtn = this.querySelector('#closeShareModal');
      const canvas = this.querySelector('#shareCanvas') as HTMLCanvasElement;
      const downloadBtn = this.querySelector('#downloadCardBtn');
      
      let selectedVerse = { text: '', ref: '' };
      
      cards.forEach(card => {
        card.addEventListener('click', (e) => {
          const el = e.currentTarget as HTMLElement;
          selectedVerse.ref = el.dataset.verseRef;
          selectedVerse.text = el.dataset.verseText;
          
          const modalRef = this.querySelector('#modalRef');
          const modalText = this.querySelector('#modalText');
          if (modalRef) modalRef.textContent = selectedVerse.ref;
          if (modalText) modalText.textContent = `"${selectedVerse.text}"`;
          
          if (modal) {
            modal.classList.add('active');
            document.body.classList.add('no-scroll');
          }
          this.drawCard(canvas, selectedVerse.text, selectedVerse.ref);
        });
      });
      
      const closeModal = () => {
        if (modal) {
          modal.classList.remove('active');
          document.body.classList.remove('no-scroll');
        }
      };

      if (closeBtn) {
        closeBtn.addEventListener('click', closeModal);
      }

      if (modal) {
        modal.addEventListener('click', (e) => {
          if (e.target === modal) {
            closeModal();
          }
        });
      }
      
      if (downloadBtn && canvas) {
        downloadBtn.addEventListener('click', () => {
          const link = document.createElement('a');
          link.download = `Ayat_${selectedVerse.ref.replace(/[\s:]/g, '_')}.png`;
          link.href = canvas.toDataURL('image/png');
          link.click();
        });
      }
    }

    drawCard(canvas: HTMLCanvasElement, text: string, ref: string) {
      const ctx = canvas.getContext('2d');
      if (!ctx) return;
      
      // Clear
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      
      // 1. Latar Belakang (Fine Parchment Warm #faf9f8)
      ctx.fillStyle = '#faf9f8';
      ctx.fillRect(0, 0, canvas.width, canvas.height);
      
      // 2. Ornamen Garis Pembatas Minimalis (Mahogany #442a22, 20% Opacity)
      ctx.strokeStyle = 'rgba(68, 42, 34, 0.2)';
      ctx.lineWidth = 2;
      ctx.strokeRect(30, 30, canvas.width - 60, canvas.height - 60);
      
      // Sub-pembatas tipis bagian dalam
      ctx.strokeStyle = 'rgba(68, 42, 34, 0.08)';
      ctx.lineWidth = 1;
      ctx.strokeRect(36, 36, canvas.width - 72, canvas.height - 72);
      
      // 3. Teks Pembuka (Inter Sans-Serif, Muted)
      ctx.fillStyle = '#7d5a50';
      ctx.font = '600 12px sans-serif';
      ctx.textAlign = 'center';
      ctx.fillText('THE SACRED LIBRARY', canvas.width / 2, 80);
      
      // 4. Ayat Utama (Georgia Serif, Mahogany #442a22, Italic)
      ctx.fillStyle = '#211613';
      ctx.font = 'italic 20px Georgia, serif';
      
      // Word wrap helper
      const words = `"${text}"`.split(' ');
      let line = '';
      let lines = [];
      const maxWidth = canvas.width - 120;
      const lineHeight = 32;
      
      for (let n = 0; n < words.length; n++) {
        let testLine = line + words[n] + ' ';
        let metrics = ctx.measureText(testLine);
        if (metrics.width > maxWidth && n > 0) {
          lines.push(line);
          line = words[n] + ' ';
        } else {
          line = testLine;
        }
      }
      lines.push(line);
      
      // Calculate starting Y to center text
      let startY = (canvas.height / 2) - ((lines.length - 1) * lineHeight / 2) - 10;
      
      for (let k = 0; k < lines.length; k++) {
        ctx.fillText(lines[k].trim(), canvas.width / 2, startY + (k * lineHeight));
      }
      
      // 5. Referensi Ayat (Sans-serif, Mahogany)
      ctx.fillStyle = '#442a22';
      ctx.font = '700 14px sans-serif';
      ctx.fillText(ref.toUpperCase(), canvas.width / 2, startY + (lines.length * lineHeight) + 20);
      
      // 6. Watermark Logo / Salib Minimalis di Bawah
      ctx.fillStyle = 'rgba(68, 42, 34, 0.3)';
      ctx.font = '20px Georgia, serif';
      ctx.fillText('†', canvas.width / 2, canvas.height - 75);
    }
    
    setupBookmark() {
      try {
        let stats = JSON.parse(localStorage.getItem('alkitab_stats') || '{"totalSwipes": 0, "streak": 0, "bookProgress": {}, "exploredBooks": []}');
        
        // 1. Save Last Read bookmark
        stats.lastRead = {
          bookId: this.bookId,
          bookName: this.bookName
        };
        
        // 2. Mark this book as Explored
        if (!stats.exploredBooks) stats.exploredBooks = [];
        if (!stats.exploredBooks.includes(this.bookId)) {
          stats.exploredBooks.push(this.bookId);
        }
        
        // 3. Mark progress as 100% since they explored the guide
        if (!stats.bookProgress) stats.bookProgress = {};
        stats.bookProgress[this.bookId] = 100;
        
        // 4. Daily Streak calculations
        const todayStr = new Date().toLocaleDateString('id-ID'); // "DD/MM/YYYY" format locally
        const lastDate = stats.lastReadDate;
        
        if (!lastDate) {
          stats.streak = 1;
        } else if (lastDate !== todayStr) {
          // Parse dates to check consecutive days
          const parseDate = (dStr: string) => {
            const parts = dStr.split('/');
            return new Date(parseInt(parts[2]), parseInt(parts[1]) - 1, parseInt(parts[0]));
          };
          
          try {
            const today = parseDate(todayStr);
            const yesterday = parseDate(lastDate);
            const diffTime = Math.abs(today.getTime() - yesterday.getTime());
            const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
            
            if (diffDays === 1) {
              stats.streak += 1;
            } else if (diffDays > 1) {
              stats.streak = 1; // broken streak
            }
          } catch(e) {
            stats.streak = 1;
          }
        }
        
        stats.lastReadDate = todayStr;
        localStorage.setItem('alkitab_stats', JSON.stringify(stats));
      } catch (e) {
        console.error("Failed to update bookmark & streak stats", e);
      }
    }
  }
  
  customElements.define('book-guide', BookGuide);
