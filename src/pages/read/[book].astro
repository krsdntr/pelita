---
import Layout from '../../layouts/Layout.astro';
import StatsHeader from '../../components/StatsHeader.astro';
import Footer from '../../components/Footer.astro';
import books from '../../data/bible-metadata.json';

// Pre-render all 73 Catholic books
export async function getStaticPaths() {
  
  return books.map((book, index) => {
    const prevBook = index > 0 ? books[index - 1] : null;
    const nextBook = index < books.length - 1 ? books[index + 1] : null;
    
    return {
      params: { book: book.id },
      props: {
        book,
        prevBook,
        nextBook
      }
    };
  });
}

const { book, prevBook, nextBook } = Astro.props;

import summaries from '../../data/catholic-summaries.json';
const summary = summaries[book.id] || {
  quote: "Teks pengantar iman Katolik.",
  tagline: `Panduan Kitab ${book.name}`,
  overview: `Kitab ${book.name} adalah bagian dari ${book.category}.`,
  author: "Penulis Tradisional",
  date: "Abad Kuno",
  context: "Informasi sejarah belum terisi.",
  theology: "Informasi teologi belum terisi.",
  structure: [],
  goldenVerses: []
};

// Formatting helper
const formatText = (text: string) => {
  return text.split('\n').map(p => {
    if (p.startsWith('*')) {
      return `<li>${p.replace(/^\*\s*/, '')}</li>`;
    }
    // Handle markdown-style bold
    let formatted = p.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>');
    return `<p class="paragraph">${formatted}</p>`;
  }).join('');
};
---

<Layout title={`Panduan ${book.name}`} description={summary.tagline}>
  <StatsHeader />
  
  <book-guide 
    data-book-id={book.id}
    data-book-name={book.name}
    class="guide-wrapper"
  >
    <div class="editorial-container container-narrow">
      
      <!-- Top Hero Section -->
      <header class="book-hero">
        <span class="type-label-md category-tag">{book.subCategory} &bull; {book.category}</span>
        <h1 class="type-display-lg book-hero-title">{book.name}</h1>
        <p class="tagline type-body-lg italic">"{summary.quote}"</p>
        <p class="sub-tagline type-label-md">{summary.tagline}</p>
        
        <!-- Metadata Pill Blocks -->
        <div class="meta-pills">
          <div class="meta-pill">
            <span class="pill-title">PENULIS</span>
            <span class="pill-value">{summary.author}</span>
          </div>
          <div class="meta-pill">
            <span class="pill-title">WAKTU</span>
            <span class="pill-value">{summary.date}</span>
          </div>
          <div class="meta-pill">
            <span class="pill-title">BAGIAN</span>
            <span class="pill-value">{book.chapters} Bab</span>
          </div>
        </div>

        <div class="read-action-container" style="margin-top: 2rem; width: 100%; max-width: 600px;">
          <a href={`/read/${book.id}/1`} class="start-reading-btn">
            MULAI MEMBACA KESELURUHAN TEKS
          </a>
        </div>
      </header>

      <!-- Sticky Tabbed Navigation -->
      <nav class="editorial-tabs" id="stickyTabs">
        <button class="tab-btn active" data-tab="overview">GERBANG</button>
        <button class="tab-btn" data-tab="history">SEJARAH</button>
        <button class="tab-btn" data-tab="theology">TEOLOGI</button>
        <button class="tab-btn" data-tab="structure">STRUKTUR</button>
        <button class="tab-btn" data-tab="devotional">RENUNGAN</button>
      </nav>

      <!-- Tab Content Area -->
      <div class="tab-view-canvas">
        
        <!-- Tab 1: Overview -->
        <section class="tab-content active" id="content-overview">
          <h2 class="type-title-lg section-title">Pintu Gerbang Kitab</h2>
          <div class="editorial-text select-text" set:html={formatText(summary.overview)}></div>
        </section>

        <!-- Tab 2: History -->
        <section class="tab-content" id="content-history">
          <h2 class="type-title-lg section-title">Lembah Sejarah & Konteks</h2>
          <div class="editorial-text select-text" set:html={formatText(summary.context)}></div>
        </section>

        <!-- Tab 3: Theology -->
        <section class="tab-content" id="content-theology">
          <h2 class="type-title-lg section-title">Ruang Teologi & Iman Katolik</h2>
          <div class="editorial-text select-text theology-block select-text" set:html={formatText(summary.theology)}></div>
        </section>

        <!-- Tab 4: Structure -->
        <section class="tab-content" id="content-structure">
          <h2 class="type-title-lg section-title">Jalan Narasi & Rangkuman Bab</h2>
          <div class="structure-list">
            {summary.structure.map((item: any) => (
              <div class="structure-card">
                <div class="struct-meta">
                  <span class="type-label-md chapters-tag">Bab {item.chapters}</span>
                  <h3 class="type-title-lg struct-title">{item.title}</h3>
                </div>
                <p class="type-body-lg struct-desc select-text">{item.summary}</p>
              </div>
            ))}
          </div>
        </section>

        <!-- Tab 5: Devotional -->
        <section class="tab-content" id="content-devotional">
          <h2 class="type-title-lg section-title">Suara Jiwa & Ayat Emas</h2>
          <div class="verses-list">
            {summary.goldenVerses.map((item: any, idx: number) => (
              <div class="verse-card-wrap">
                <div class="verse-vellum-card select-text" data-verse-ref={item.verse} data-verse-text={item.text}>
                  <sup class="verse-num-badge">{idx + 1}</sup>
                  <p class="type-title-lg verse-quote">"{item.text}"</p>
                  <span class="type-label-md verse-source">{item.verse}</span>
                </div>
                <div class="verse-reflection">
                  <span class="type-label-md ref-title">REFLEKSI IMAN KATOLIK</span>
                  <p class="type-body-lg ref-text select-text">{item.reflection}</p>
                </div>
              </div>
            ))}
          </div>
        </section>

      </div>

      <!-- Book Footer Navigation -->
      <footer class="guide-footer">
        {prevBook ? (
          <a href={`/read/${prevBook.id}`} class="footer-nav-link prev">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" width="16" height="16">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
            <div class="nav-details">
              <span class="type-label-md font-tiny">SEBELUMNYA</span>
              <span class="nav-book-name">{prevBook.name}</span>
            </div>
          </a>
        ) : <div class="nav-spacer"></div>}

        <a href="/" class="bookshelf-return-btn type-label-md">RAK BUKU</a>

        {nextBook ? (
          <a href={`/read/${nextBook.id}`} class="footer-nav-link next">
            <div class="nav-details">
              <span class="type-label-md font-tiny">SELANJUTNYA</span>
              <span class="nav-book-name">{nextBook.name}</span>
            </div>
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" width="16" height="16">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        ) : <div class="nav-spacer"></div>}
      </footer>

    </div>

    <!-- Share Card Modal -->
    <div class="share-modal" id="shareModal">
      <div class="share-modal-content">
        <header class="modal-header">
          <span class="type-label-md">BAGIKAN AYAT SUCI</span>
          <button class="drawer-close-btn" id="closeShareModal" aria-label="Tutup">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" width="20" height="20"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
          </button>
        </header>
        
        <div class="modal-body">
          <!-- Canvas for generating the card image -->
          <div class="canvas-container">
            <canvas id="shareCanvas" width="500" height="500"></canvas>
          </div>
          
          <div class="preview-verse-details" style="display: none;">
            <p id="modalText"></p>
            <span id="modalRef"></span>
          </div>
          
          <button class="btn-primary type-label-md" id="downloadCardBtn" style="display: flex; align-items: center; justify-content: center; gap: 0.5rem; cursor: pointer;">
            UNDUH KARTU GAMBAR
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" width="16" height="16" style="display: inline-block;">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
            </svg>
          </button>
        </div>
      </div>
    </div>
  </book-guide>
  <Footer />
</Layout>

<style>
